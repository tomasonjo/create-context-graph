# {{ domain.name }} Context Graph Application
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# WARNING: Change all default credentials before deploying to any
# network-accessible environment. Never commit real credentials to git.

# Memory backend: 'nams' (default — hosted) or 'bolt' (self-hosted Neo4j)
MEMORY_BACKEND={{ memory_backend }}

{% if is_nams %}
# Neo4j Agent Memory Service (NAMS) — hosted memory backend
# Obtain an API key at https://memory.neo4jlabs.com
MEMORY_API_KEY=your-nams-api-key-here
# MEMORY_NAMS_ENDPOINT={{ nams_endpoint }}  # Override only if pointing at a self-hosted NAMS gateway
{% else %}
# Self-hosted Neo4j (Bolt)
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here
{% endif %}

# Memory layer LLM + embedding provider (LiteLLM-style strings, optional).
# Native providers are resolved first; everything else routes through LiteLLM.
#
# Examples (uncomment one):
# MEMORY_LLM=anthropic/claude-haiku-4-5             # Anthropic native
# MEMORY_LLM=openai/gpt-4o-mini                     # OpenAI native
# MEMORY_LLM=bedrock/anthropic.claude-3-haiku-20240307-v1:0  # AWS Bedrock via LiteLLM
# MEMORY_LLM=vertex_ai/gemini-1.5-flash             # Google Vertex AI via LiteLLM
# MEMORY_LLM=ollama/llama3                          # Local Ollama via LiteLLM
MEMORY_LLM=
# MEMORY_EMBEDDING=sentence-transformers/all-MiniLM-L6-v2   # Local (default fallback)
# MEMORY_EMBEDDING=openai/text-embedding-3-small            # OpenAI native
MEMORY_EMBEDDING=

# LLM API Keys (for the agent — set the one your selected framework needs)
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=  # Optional: enables OpenAI embeddings for conversation memory (local sentence-transformers used by default)
GOOGLE_API_KEY=your-google-api-key-here  # Required for google-adk framework
# ANTHROPIC_MODEL=claude-sonnet-4-20250514  # Override default model for Claude Agent SDK

# Application
DOMAIN_ID={{ domain.id }}
SESSION_STRATEGY={{ session_strategy }}
BACKEND_PORT=8000
FRONTEND_PORT=3000

{% if 'github' in saas_connectors %}
# GitHub (repository data import)
GITHUB_TOKEN=your-github-pat-here  # Settings > Developer settings > Personal access tokens
GITHUB_REPO=owner/repo             # e.g. neo4j-labs/create-context-graph
GITHUB_LIMIT=20                    # Default max for issues, PRs, and commits
# GITHUB_ISSUES_LIMIT=20           # Override GITHUB_LIMIT for issues only
# GITHUB_PRS_LIMIT=20              # Override GITHUB_LIMIT for pull requests only
# GITHUB_COMMITS_LIMIT=20          # Override GITHUB_LIMIT for commits only
GITHUB_IMPORT_BODY=true            # Store issue/PR bodies as Documents
GITHUB_LINK_ISSUES_PRS=true        # Detect CLOSES/REFERENCES links between issues, PRs, and commits
GITHUB_LINK_SOURCE=both            # regex | graphql | both (regex scans bodies; graphql queries closingIssuesReferences per PR)
{% endif %}
{% if 'notion' in saas_connectors %}
# Notion (knowledge base import)
NOTION_TOKEN=your-notion-integration-token-here
{% endif %}
{% if 'jira' in saas_connectors %}
# Jira (issue tracking import)
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_TOKEN=your-jira-api-token-here
JIRA_PROJECT=your-project-key  # e.g. ENG
{% endif %}
{% if 'slack' in saas_connectors %}
# Slack (channel history import)
SLACK_TOKEN=your-slack-bot-token-here  # xoxb-...
{% endif %}
{% if 'salesforce' in saas_connectors %}
# Salesforce (CRM data import)
SALESFORCE_USERNAME=your-username@example.com
SALESFORCE_PASSWORD=your-password-here
SALESFORCE_SECURITY_TOKEN=your-security-token-here
{% endif %}
{% if 'linear' in saas_connectors %}
# Linear (project management import)
LINEAR_API_KEY=your-linear-api-key-here  # From Linear Settings > Security & Access > API
LINEAR_TEAM=  # Optional: team key to filter import (e.g., ENG)
{% endif %}
{% if 'google-workspace' in saas_connectors %}
# Google Workspace (decision trace import from Drive, Calendar, Gmail)
GOOGLE_CLIENT_ID=your-client-id-here  # From Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_SECRET=your-client-secret-here
GWS_FOLDER_ID=  # Optional: Drive folder ID to scope import (recommended)
{% endif %}
# CORS — comma-separated origins allowed for frontend (default: http://localhost:3000)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Suppress HuggingFace Hub warnings (set HF_TOKEN for higher rate limits)
HF_HUB_DISABLE_TELEMETRY=1
# HF_TOKEN=your-huggingface-token-here
