[project]
name = "{{ project_slug }}-backend"
version = "0.1.0"
description = "{{ domain.name }} Context Graph Backend"
{% if framework == 'crewai' -%}
requires-python = ">=3.11, <3.14"
{% else -%}
requires-python = ">=3.10, <3.14"
{% endif -%}
dependencies = [
    "fastapi>=0.115",
    "uvicorn[standard]>=0.30",
    "pydantic>=2.0",
    "pydantic-settings>=2.0",
    "neo4j>=5.20",
{% if is_nams %}
    "neo4j-agent-memory[litellm,sentence-transformers]>=0.4.0,<0.6.0",
{% else %}
    "neo4j-agent-memory[litellm,sentence-transformers,extraction,fuzzy]>=0.4.0,<0.6.0",
{% endif %}
{% for dep in framework_deps %}
    "{{ dep }}",
{% endfor %}
{% if 'github' in saas_connectors %}
    "PyGithub>=2.0",
{% endif %}
{% if 'notion' in saas_connectors %}
    "notion-client>=2.0",
{% endif %}
{% if 'jira' in saas_connectors %}
    "atlassian-python-api>=3.0",
{% endif %}
{% if 'slack' in saas_connectors %}
    "slack-sdk>=3.0",
{% endif %}
{% if 'salesforce' in saas_connectors %}
    "simple-salesforce>=1.0",
{% endif %}
{% if 'gmail' in saas_connectors or 'gcal' in saas_connectors or 'google-workspace' in saas_connectors %}
    "google-api-python-client>=2.0",
    "google-auth-oauthlib>=1.0",
{% endif %}
]

[tool.hatch.build.targets.wheel]
packages = ["app"]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"
