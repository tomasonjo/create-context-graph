{% raw %}
# ---------------------------------------------------------------------------
# Extended thinking → reasoning traces
# ---------------------------------------------------------------------------


def _thinking_config() -> dict | None:
    """Anthropic extended-thinking config used to capture the model's reasoning.

    The captured thinking becomes the ``thought`` of each reasoning trace step.
    Set ANTHROPIC_THINKING=0 to disable (the trace panel then falls back to a
    rationale summarized from the tool inputs). Tune the token budget with
    ANTHROPIC_THINKING_BUDGET (minimum 1024).
    """
    if os.getenv("ANTHROPIC_THINKING", "1").strip().lower() in ("0", "false", "no", "off"):
        return None
    try:
        budget = int(os.getenv("ANTHROPIC_THINKING_BUDGET", "1024"))
    except ValueError:
        budget = 1024
    return {"type": "enabled", "budget_tokens": max(budget, 1024)}


_THINKING = _thinking_config()
# Thinking tokens count against max_tokens, so reserve headroom for the answer.
_MAX_TOKENS = 4096 + (_THINKING["budget_tokens"] if _THINKING else 0)
# PydanticAI model settings (AnthropicModelSettings is a TypedDict at runtime, so
# a plain dict works and avoids a hard import). None ⇒ thinking disabled.
# ``anthropic_betas`` enables interleaved thinking so the model reasons before
# EACH tool call (not just the first turn) — distinct thought per trace step.
_MODEL_SETTINGS = (
    {
        "max_tokens": _MAX_TOKENS,
        "anthropic_thinking": _THINKING,
        "anthropic_betas": ["interleaved-thinking-2025-05-14"],
    }
    if _THINKING
    else None
)


def _capture_run_thinking(collector, result) -> None:
    """Feed a completed run's thinking blocks into the collector for traces.

    PydanticAI runs the whole tool loop inside ``agent.run()``, so we can't stamp
    a "pending thought" before each tool like the raw-Anthropic agents do.
    Instead we reconstruct it afterwards: each ``ThinkingPart`` is paired with the
    ``ToolCallPart``s in the same ``ModelResponse``. Interleaved thinking gives
    each turn its own thought; if a turn has none, we carry the last thought
    forward (rather than dropping to the templated rationale). Matched onto the
    collected tool calls by name and order. Best-effort — if the installed
    pydantic-ai doesn't expose thinking parts, the templated rationale stands.
    """
    try:
        from pydantic_ai.messages import ModelResponse, ThinkingPart, ToolCallPart
    except Exception:
        return
    try:
        messages = result.new_messages()
    except Exception:
        return

    per_tool: list[tuple[str, str]] = []  # (tool_name, thought) in model order
    final: list[str] = []                 # thinking from tool-less (answer) turns
    last_thinking = ""                    # carried forward across thought-less turns
    for msg in messages:
        if not isinstance(msg, ModelResponse):
            continue
        thinking = "\n".join(
            getattr(p, "content", "")
            for p in msg.parts
            if isinstance(p, ThinkingPart) and getattr(p, "content", "")
        ).strip()
        if thinking:
            last_thinking = thinking
        effective = thinking or last_thinking
        tool_parts = [p for p in msg.parts if isinstance(p, ToolCallPart)]
        if tool_parts:
            for p in tool_parts:
                per_tool.append((getattr(p, "tool_name", ""), effective))
        elif thinking:
            final.append(thinking)

    # Attach per-call thoughts to the collected tool calls, matched by name+order.
    idx = 0
    for tc in collector.tool_calls:
        name = tc.get("name")
        while idx < len(per_tool) and per_tool[idx][0] != name:
            idx += 1
        if idx < len(per_tool):
            if per_tool[idx][1]:
                tc["thought"] = per_tool[idx][1]
            idx += 1

    for thought in final:
        collector.record_thinking(thought)


@agent.tool
async def run_cypher(ctx: RunContext[AgentDeps], query: str, parameters: str = "{}") -> str:
    """Execute a read-only Cypher query against the knowledge graph."""
    try:
        params = json.loads(parameters) if parameters else {}
    except json.JSONDecodeError:
        return json.dumps([{"error": "Invalid JSON parameters"}])
    params.setdefault("domain", settings.domain_id)
    try:
        result = await execute_cypher(query, params, tool_name="run_cypher")
        return json.dumps(result, default=str)
    except Exception as e:
        return json.dumps([{"error": f"Cypher query failed: {e}"}])


@agent.tool
async def get_graph_schema(ctx: RunContext[AgentDeps]) -> str:
    """Get the knowledge graph schema (node labels and relationship types)."""
    result = await get_schema()
    return json.dumps(result, default=str)


# ---------------------------------------------------------------------------
# Message handler
# ---------------------------------------------------------------------------


async def handle_message(message: str, session_id: str | None = None) -> dict:
    """Handle an incoming chat message."""
    session_id = resolve_session_id(session_id)
    collector = get_collector()

    # Store user message (triggers entity extraction + preference detection)
    await store_message(session_id, "user", message)

    # Get rich context (messages + entities + preferences + traces)
    context = await get_context(session_id, query=message)
    history = context.get("messages", [])

    # Convert history to PydanticAI message format
    from pydantic_ai.messages import ModelRequest, ModelResponse, UserPromptPart, TextPart
    message_history = []
    for msg in history:
        if msg["role"] == "user":
            message_history.append(
                ModelRequest(parts=[UserPromptPart(content=msg["content"])])
            )
        elif msg["role"] == "assistant":
            message_history.append(
                ModelResponse(parts=[TextPart(content=msg["content"])])
            )

    deps = AgentDeps(session_id=session_id)
    result = await agent.run(
        message, deps=deps, message_history=message_history,
        model_settings=_MODEL_SETTINGS,
    )
    _capture_run_thinking(collector, result)

    response_text = result.output or ""
    if not response_text.strip():
        response_text = "I searched the knowledge graph but couldn't find relevant results for your query. Could you try rephrasing your question?"
    assistant_result = await store_message(session_id, "assistant", response_text)

    return {
        "response": response_text,
        "session_id": session_id,
        "graph_data": None,
        "entities_extracted": (assistant_result or {}).get("entities", []),
        "preferences_detected": (assistant_result or {}).get("preferences", []),
    }


async def handle_message_stream(message: str, session_id: str | None = None) -> dict:
    """Handle a chat message with streaming text deltas via the collector event queue."""
    from app.context_graph_client import get_collector

    session_id = resolve_session_id(session_id)

    collector = get_collector()
    await store_message(session_id, "user", message)

    # Get rich context (messages + entities + preferences + traces)
    context = await get_context(session_id, query=message)
    history = context.get("messages", [])

    # Convert history to PydanticAI message format
    from pydantic_ai.messages import ModelRequest, ModelResponse, UserPromptPart, TextPart
    message_history = []
    for msg in history:
        if msg["role"] == "user":
            message_history.append(
                ModelRequest(parts=[UserPromptPart(content=msg["content"])])
            )
        elif msg["role"] == "assistant":
            message_history.append(
                ModelResponse(parts=[TextPart(content=msg["content"])])
            )

    deps = AgentDeps(session_id=session_id)
    # Use agent.run() (not run_stream) so the full agent loop completes —
    # including all tool calls — before we emit the final text.
    # run_stream stops at the first text part, so it cuts off before tool
    # results are incorporated when Claude generates "I'll search..." + a tool
    # call in the same response.  Tool events (tool_start / tool_end) are still
    # pushed to the SSE queue by execute_cypher during the run.
    result = await agent.run(
        message, deps=deps, message_history=message_history,
        model_settings=_MODEL_SETTINGS,
    )
    _capture_run_thinking(collector, result)

    response_text = result.output or ""
    if not response_text.strip():
        response_text = "I searched the knowledge graph but couldn't find relevant results for your query. Could you try rephrasing your question?"

    collector.emit_text_delta(response_text)
    assistant_result = await store_message(session_id, "assistant", response_text)
    if assistant_result:
        collector.emit_entities_extracted(assistant_result.get("entities", []))
        collector.emit_preferences_detected(assistant_result.get("preferences", []))
    collector.emit_done(response_text, session_id)

    return {
        "response": response_text,
        "session_id": session_id,
        "graph_data": None,
    }
