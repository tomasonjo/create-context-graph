{% raw %}"use client";

import { useState, useEffect } from "react";
import { Box, Heading, Text, VStack, HStack, Badge, Flex, Dialog, Portal, CloseButton, Button, Textarea, Input } from "@chakra-ui/react";
import { GitBranch, Brain, Wrench, Eye, ThumbsUp, ThumbsDown, MessageSquare, Check } from "lucide-react";
import { API_BASE } from "@/lib/config";

// Quick issue/quality labels a reviewer can attach to a trace. These become
// structured tags in the exported HITL dataset used to curate guidelines.
const FEEDBACK_TAGS = [
  "Correct",
  "Wrong answer",
  "Wrong tool",
  "Bad query",
  "Hallucinated",
  "Incomplete",
  "Inefficient",
  "Good reasoning",
];

interface ReasoningStep {
  step_number: number;
  thought: string;
  action: string;
  observation?: string;
}

interface StepFeedback {
  step_number: number;
  rating?: string;
  note?: string;
}

interface TraceFeedback {
  trace_id?: string;
  rating?: string; // "up" | "down" | "unset"
  tags?: string[];
  note?: string;
  reviewer?: string;
  task?: string;
  step_feedback?: StepFeedback[];
  updated_at?: string;
}

interface ReasoningTrace {
  id: string;
  task: string;
  steps: ReasoningStep[];
  outcome: string;
  feedback?: TraceFeedback;
}

function hasFeedbackSignal(fb?: TraceFeedback): boolean {
  if (!fb) return false;
  return (
    (!!fb.rating && fb.rating !== "unset") ||
    (fb.tags?.length || 0) > 0 ||
    !!(fb.note && fb.note.trim()) ||
    (fb.step_feedback?.length || 0) > 0
  );
}

export function ReasoningTracePanel() {
  const [traces, setTraces] = useState<ReasoningTrace[]>([]);
  const [selectedTrace, setSelectedTrace] = useState<ReasoningTrace | null>(null);
  const [draft, setDraft] = useState<TraceFeedback>({});
  const [saving, setSaving] = useState(false);
  const [saved, setSaved] = useState(false);

  useEffect(() => {
    loadTraces();
    const interval = window.setInterval(loadTraces, 5000);
    return () => window.clearInterval(interval);
  }, []);

  // Initialize the feedback draft when a different trace is opened. Keyed on the
  // trace id (not the object) so refreshing a trace's own feedback after a save
  // doesn't reset the form or wipe the "Saved" indicator.
  useEffect(() => {
    if (!selectedTrace) return;
    setDraft(
      selectedTrace.feedback
        ? { ...selectedTrace.feedback }
        : { rating: "unset", tags: [], note: "", step_feedback: [] }
    );
    setSaved(false);
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [selectedTrace?.id]);

  async function loadTraces() {
    try {
      const res = await fetch(`${API_BASE}/traces`, { signal: AbortSignal.timeout(10000) });
      const data = await res.json();
      if (data.traces) {
        setTraces(
          data.traces.map((t: Record<string, unknown>) => ({
            id: (t.id as string) || "",
            task: (t.task as string) || "",
            steps: ((t.steps as ReasoningStep[]) || []).filter(
              (s) => s && s.thought
            ),
            outcome: (t.outcome as string) || "",
            feedback: (t.feedback as TraceFeedback) || undefined,
          }))
        );
      }
    } catch {
      // Backend may not be running yet
    }
  }

  function setRating(rating: string) {
    setDraft((d) => ({ ...d, rating: d.rating === rating ? "unset" : rating }));
    setSaved(false);
  }

  function toggleTag(tag: string) {
    setDraft((d) => {
      const tags = new Set(d.tags || []);
      if (tags.has(tag)) tags.delete(tag);
      else tags.add(tag);
      return { ...d, tags: Array.from(tags) };
    });
    setSaved(false);
  }

  function stepNoteValue(stepNumber: number): string {
    return (draft.step_feedback || []).find((s) => s.step_number === stepNumber)?.note || "";
  }

  function setStepNote(stepNumber: number, note: string) {
    setDraft((d) => {
      const list = [...(d.step_feedback || [])];
      const idx = list.findIndex((s) => s.step_number === stepNumber);
      if (idx >= 0) list[idx] = { ...list[idx], step_number: stepNumber, note };
      else list.push({ step_number: stepNumber, note });
      return { ...d, step_feedback: list };
    });
    setSaved(false);
  }

  async function saveFeedback() {
    if (!selectedTrace) return;
    setSaving(true);
    try {
      const payload = {
        rating: draft.rating || "unset",
        tags: draft.tags || [],
        note: draft.note || "",
        reviewer: draft.reviewer || "",
        task: selectedTrace.task,
        step_feedback: (draft.step_feedback || []).filter(
          (s) => (s.note || "").trim() || (s.rating && s.rating !== "unset")
        ),
      };
      const res = await fetch(
        `${API_BASE}/traces/${encodeURIComponent(selectedTrace.id)}/feedback`,
        {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
          signal: AbortSignal.timeout(10000),
        }
      );
      if (res.ok) {
        const record = (await res.json()) as TraceFeedback;
        setDraft(record);
        setSaved(true);
        // Reflect the saved feedback into the list (badge) and the open trace
        // without re-triggering the draft-init effect (same trace id).
        setTraces((prev) =>
          prev.map((t) => (t.id === selectedTrace.id ? { ...t, feedback: record } : t))
        );
        setSelectedTrace((t) => (t ? { ...t, feedback: record } : t));
      }
    } catch {
      // Leave the draft intact so the reviewer can retry
    } finally {
      setSaving(false);
    }
  }

  return (
    <Flex direction="column" h="100%">
      <Box px={4} py={3} borderBottom="1px solid" borderColor="gray.200">
        <Heading size="sm">
          <HStack>
            <GitBranch size={16} />
            <span>Reasoning Traces</span>
          </HStack>
        </Heading>
        <Text fontSize="xs" color="gray.500">
          Reasoning provenance & causal chains
        </Text>
      </Box>

      <VStack flex={1} overflow="auto" px={4} py={2} gap={2} align="stretch">
        {traces.length === 0 ? (
          <Box py={8} px={4}>
            <Flex justify="center" mb={3}>
              <GitBranch size={32} color="#A0AEC0" />
            </Flex>
            <Text fontSize="sm" color="gray.500" textAlign="center">
              No reasoning traces yet
            </Text>
            <Text fontSize="xs" color="gray.400" textAlign="center" mt={2} lineHeight="tall">
              Reasoning traces capture multi-step chains — the thoughts,
              actions, and observations an agent uses to reach a conclusion.
            </Text>
            <Box mt={3} textAlign="center">
              <Badge variant="outline" fontSize="xs" fontFamily="mono" px={2}>
                make seed
              </Badge>
            </Box>
          </Box>
        ) : (
          traces.map((trace) => (
            <Box
              key={trace.id}
              p={3}
              borderRadius="md"
              border="1px solid"
              borderColor={
                selectedTrace?.id === trace.id ? "blue.300" : "gray.200"
              }
              cursor="pointer"
              onClick={() => setSelectedTrace(trace)}
              _hover={{ borderColor: "blue.200" }}
            >
              <Text fontSize="sm" fontWeight="medium" lineClamp={2}>
                {trace.task}
              </Text>
              <HStack mt={1}>
                <Badge size="sm" variant="outline">
                  <Brain size={10} />
                  {trace.steps.length} steps
                </Badge>
                {trace.outcome && (
                  <Badge size="sm" colorPalette="green">
                    Resolved
                  </Badge>
                )}
                {hasFeedbackSignal(trace.feedback) && (
                  <Badge
                    size="sm"
                    colorPalette={
                      trace.feedback?.rating === "down"
                        ? "red"
                        : trace.feedback?.rating === "up"
                        ? "green"
                        : "purple"
                    }
                  >
                    {trace.feedback?.rating === "up" ? (
                      <ThumbsUp size={10} />
                    ) : trace.feedback?.rating === "down" ? (
                      <ThumbsDown size={10} />
                    ) : (
                      <MessageSquare size={10} />
                    )}
                    Reviewed
                  </Badge>
                )}
              </HStack>
            </Box>
          ))
        )}
      </VStack>

      {/* Selected trace detail — opens in a centered modal */}
      <Dialog.Root
        open={!!selectedTrace}
        onOpenChange={(e) => {
          if (!e.open) setSelectedTrace(null);
        }}
        size="lg"
        scrollBehavior="inside"
      >
        <Portal>
          <Dialog.Backdrop />
          <Dialog.Positioner>
            <Dialog.Content>
              <Dialog.CloseTrigger asChild>
                <CloseButton size="sm" />
              </Dialog.CloseTrigger>
              <Dialog.Header>
                <HStack gap={2}>
                  <GitBranch size={16} />
                  <Dialog.Title fontSize="sm">{selectedTrace?.task}</Dialog.Title>
                </HStack>
              </Dialog.Header>
              <Dialog.Body pb={6}>
                {selectedTrace && (
                  <>
                    <VStack gap={3} align="stretch">
                      {selectedTrace.steps.map((step, i) => (
                        <Box
                          key={`step-${i}-${(step.action || "").slice(0, 32)}`}
                          pl={3}
                          borderLeft="2px solid"
                          borderColor="blue.200"
                        >
                          <HStack align="flex-start" gap={2}>
                            <Box mt="2px" flexShrink={0}>
                              <Brain size={12} />
                            </Box>
                            <Text fontSize="xs" color="gray.600">
                              {step.thought}
                            </Text>
                          </HStack>
                          <HStack align="flex-start" gap={2} mt={1}>
                            <Box mt="2px" flexShrink={0}>
                              <Wrench size={12} />
                            </Box>
                            <Box
                              as="pre"
                              flex={1}
                              fontSize="xs"
                              fontFamily="mono"
                              whiteSpace="pre-wrap"
                              wordBreak="break-word"
                              bg="gray.50"
                              px={2}
                              py={1}
                              borderRadius="sm"
                            >
                              {step.action}
                            </Box>
                          </HStack>
                          {step.observation && (
                            <HStack align="flex-start" gap={2} mt={1}>
                              <Box mt="2px" flexShrink={0}>
                                <Eye size={12} />
                              </Box>
                              <Text
                                fontSize="xs"
                                color="green.700"
                                whiteSpace="pre-wrap"
                                wordBreak="break-word"
                              >
                                {step.observation}
                              </Text>
                            </HStack>
                          )}
                          <HStack align="center" gap={2} mt={2}>
                            <Box flexShrink={0}>
                              <MessageSquare size={12} color="#A0AEC0" />
                            </Box>
                            <Input
                              flex={1}
                              size="xs"
                              fontSize="xs"
                              variant="subtle"
                              placeholder="Note on this step (optional)"
                              value={stepNoteValue(step.step_number ?? i + 1)}
                              onChange={(e) =>
                                setStepNote(step.step_number ?? i + 1, e.target.value)
                              }
                            />
                          </HStack>
                        </Box>
                      ))}
                    </VStack>
                    {selectedTrace.outcome && (
                      <Box mt={4} p={2} bg="green.50" borderRadius="md">
                        <Text fontSize="xs" fontWeight="bold">
                          Outcome:
                        </Text>
                        <Text
                          fontSize="xs"
                          whiteSpace="pre-wrap"
                          wordBreak="break-word"
                        >
                          {selectedTrace.outcome}
                        </Text>
                      </Box>
                    )}

                    {/* Human-in-the-loop feedback — reviewers rate the
                        reasoning and leave guidance that is exported for
                        downstream guideline curation. */}
                    <Box mt={5} pt={4} borderTop="1px solid" borderColor="gray.200">
                      <HStack justify="space-between" mb={1}>
                        <HStack gap={2}>
                          <MessageSquare size={14} />
                          <Text fontSize="sm" fontWeight="bold">
                            Human feedback
                          </Text>
                        </HStack>
                        <Text fontSize="xs" color="gray.400">
                          {draft.updated_at
                            ? `Saved ${new Date(draft.updated_at).toLocaleString()}`
                            : "Not yet reviewed"}
                        </Text>
                      </HStack>
                      <Text fontSize="xs" color="gray.500" mb={3}>
                        Rate this reasoning and leave guidance. Saved feedback is
                        exportable for curating agent guidelines.
                      </Text>

                      <HStack gap={2} mb={3}>
                        <Button
                          size="xs"
                          variant={draft.rating === "up" ? "solid" : "outline"}
                          colorPalette="green"
                          onClick={() => setRating("up")}
                          aria-label="Rate reasoning good"
                        >
                          <ThumbsUp size={12} /> Good
                        </Button>
                        <Button
                          size="xs"
                          variant={draft.rating === "down" ? "solid" : "outline"}
                          colorPalette="red"
                          onClick={() => setRating("down")}
                          aria-label="Rate reasoning bad"
                        >
                          <ThumbsDown size={12} /> Bad
                        </Button>
                      </HStack>

                      <Flex wrap="wrap" gap={2} mb={3}>
                        {FEEDBACK_TAGS.map((tag) => {
                          const active = (draft.tags || []).includes(tag);
                          return (
                            <Badge
                              key={tag}
                              cursor="pointer"
                              px={2}
                              py={1}
                              variant={active ? "solid" : "outline"}
                              colorPalette={active ? "blue" : "gray"}
                              onClick={() => toggleTag(tag)}
                            >
                              {tag}
                            </Badge>
                          );
                        })}
                      </Flex>

                      <Textarea
                        value={draft.note || ""}
                        onChange={(e) => {
                          const value = e.target.value;
                          setDraft((d) => ({ ...d, note: value }));
                          setSaved(false);
                        }}
                        placeholder="What was right or wrong? What should the agent do next time? (becomes a guideline)"
                        fontSize="xs"
                        rows={3}
                        mb={2}
                      />

                      <Input
                        value={draft.reviewer || ""}
                        onChange={(e) => {
                          const value = e.target.value;
                          setDraft((d) => ({ ...d, reviewer: value }));
                          setSaved(false);
                        }}
                        placeholder="Reviewer (optional)"
                        fontSize="xs"
                        size="sm"
                        mb={3}
                      />

                      <HStack gap={3}>
                        <Button
                          size="sm"
                          colorPalette="blue"
                          onClick={saveFeedback}
                          loading={saving}
                          loadingText="Saving"
                        >
                          Save feedback
                        </Button>
                        {saved && (
                          <HStack gap={1} color="green.600">
                            <Check size={12} />
                            <Text fontSize="xs">Saved</Text>
                          </HStack>
                        )}
                      </HStack>
                    </Box>
                  </>
                )}
              </Dialog.Body>
            </Dialog.Content>
          </Dialog.Positioner>
        </Portal>
      </Dialog.Root>
    </Flex>
  );
}
{% endraw %}
