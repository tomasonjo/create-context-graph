{% raw %}"use client";

import { useState, useEffect } from "react";
import { Box, Heading, Text, VStack, HStack, Badge, Flex, Dialog, Portal, CloseButton, Button, Textarea, Input } from "@chakra-ui/react";
import { GitBranch, Brain, Wrench, Eye, ThumbsUp, ThumbsDown, MessageSquare, Check } from "lucide-react";
import { API_BASE } from "@/lib/config";

// Quick issue/quality labels a reviewer can attach to a trace. These become
// structured tags in the exported HITL dataset used to curate guidelines.
const FEEDBACK_TAGS = [
  "Correct",
  "Wrong answer",
  "Wrong tool",
  "Bad query",
  "Hallucinated",
  "Incomplete",
  "Inefficient",
  "Good reasoning",
];

interface ReasoningStep {
  step_number: number;
  thought: string;
  action: string;
  observation?: string;
}

interface StepFeedback {
  step_number: number;
  rating?: string;
  note?: string;
}

interface TraceFeedback {
  trace_id?: string;
  rating?: string; // "up" | "down" | "unset"
  tags?: string[];
  note?: string;
  reviewer?: string;
  task?: string;
  step_feedback?: StepFeedback[];
  updated_at?: string;
}

interface ReasoningTrace {
  id: string;
  task: string;
  steps: ReasoningStep[];
  outcome: string;
  feedback?: TraceFeedback;
}

function hasFeedbackSignal(fb?: TraceFeedback): boolean {
  if (!fb) return false;
  return (
    (!!fb.rating && fb.rating !== "unset") ||
    (fb.tags?.length || 0) > 0 ||
    !!(fb.note && fb.note.trim()) ||
    (fb.step_feedback?.length || 0) > 0
  );
}

export function ReasoningTracePanel() {
  const [traces, setTraces] = useState<ReasoningTrace[]>([]);
  const [selectedTrace, setSelectedTrace] = useState<ReasoningTrace | null>(null);
  const [draft, setDraft] = useState<TraceFeedback>({});
  const [saving, setSaving] = useState(false);
  const [saved, setSaved] = useState(false);
  // Step numbers whose note input is revealed (keeps the step list uncluttered).
  const [openNotes, setOpenNotes] = useState<Set<number>>(new Set());

  useEffect(() => {
    loadTraces();
    const interval = window.setInterval(loadTraces, 5000);
    return () => window.clearInterval(interval);
  }, []);

  // Initialize the feedback draft when a different trace is opened. Keyed on the
  // trace id (not the object) so refreshing a trace's own feedback after a save
  // doesn't reset the form or wipe the "Saved" indicator.
  useEffect(() => {
    if (!selectedTrace) return;
    setDraft(
      selectedTrace.feedback
        ? { ...selectedTrace.feedback }
        : { rating: "unset", tags: [], note: "", step_feedback: [] }
    );
    setSaved(false);
    setOpenNotes(new Set());
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [selectedTrace?.id]);

  async function loadTraces() {
    try {
      const res = await fetch(`${API_BASE}/traces`, { signal: AbortSignal.timeout(10000) });
      const data = await res.json();
      if (data.traces) {
        setTraces(
          data.traces.map((t: Record<string, unknown>) => ({
            id: (t.id as string) || "",
            task: (t.task as string) || "",
            steps: ((t.steps as ReasoningStep[]) || []).filter(
              (s) => s && s.thought
            ),
            outcome: (t.outcome as string) || "",
            feedback: (t.feedback as TraceFeedback) || undefined,
          }))
        );
      }
    } catch {
      // Backend may not be running yet
    }
  }

  function setRating(rating: string) {
    setDraft((d) => ({ ...d, rating: d.rating === rating ? "unset" : rating }));
    setSaved(false);
  }

  function toggleTag(tag: string) {
    setDraft((d) => {
      const tags = new Set(d.tags || []);
      if (tags.has(tag)) tags.delete(tag);
      else tags.add(tag);
      return { ...d, tags: Array.from(tags) };
    });
    setSaved(false);
  }

  function stepNoteValue(stepNumber: number): string {
    return (draft.step_feedback || []).find((s) => s.step_number === stepNumber)?.note || "";
  }

  function setStepNote(stepNumber: number, note: string) {
    setDraft((d) => {
      const list = [...(d.step_feedback || [])];
      const idx = list.findIndex((s) => s.step_number === stepNumber);
      if (idx >= 0) list[idx] = { ...list[idx], step_number: stepNumber, note };
      else list.push({ step_number: stepNumber, note });
      return { ...d, step_feedback: list };
    });
    setSaved(false);
  }

  function toggleStepNoteOpen(stepNumber: number) {
    setOpenNotes((prev) => {
      const next = new Set(prev);
      if (next.has(stepNumber)) next.delete(stepNumber);
      else next.add(stepNumber);
      return next;
    });
  }

  async function saveFeedback() {
    if (!selectedTrace) return;
    setSaving(true);
    try {
      const payload = {
        rating: draft.rating || "unset",
        tags: draft.tags || [],
        note: draft.note || "",
        reviewer: draft.reviewer || "",
        task: selectedTrace.task,
        step_feedback: (draft.step_feedback || []).filter(
          (s) => (s.note || "").trim() || (s.rating && s.rating !== "unset")
        ),
      };
      const res = await fetch(
        `${API_BASE}/traces/${encodeURIComponent(selectedTrace.id)}/feedback`,
        {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
          signal: AbortSignal.timeout(10000),
        }
      );
      if (res.ok) {
        const record = (await res.json()) as TraceFeedback;
        setDraft(record);
        setSaved(true);
        // Reflect the saved feedback into the list (badge) and the open trace
        // without re-triggering the draft-init effect (same trace id).
        setTraces((prev) =>
          prev.map((t) => (t.id === selectedTrace.id ? { ...t, feedback: record } : t))
        );
        setSelectedTrace((t) => (t ? { ...t, feedback: record } : t));
      }
    } catch {
      // Leave the draft intact so the reviewer can retry
    } finally {
      setSaving(false);
    }
  }

  return (
    <Flex direction="column" h="100%">
      <Box px={4} py={3} borderBottom="1px solid" borderColor="gray.200">
        <Heading size="sm">
          <HStack>
            <GitBranch size={16} />
            <span>Reasoning Traces</span>
          </HStack>
        </Heading>
        <Text fontSize="xs" color="gray.500">
          Reasoning provenance & causal chains
        </Text>
      </Box>

      <VStack flex={1} overflow="auto" px={4} py={2} gap={2} align="stretch">
        {traces.length === 0 ? (
          <Box py={8} px={4}>
            <Flex justify="center" mb={3}>
              <GitBranch size={32} color="#A0AEC0" />
            </Flex>
            <Text fontSize="sm" color="gray.500" textAlign="center">
              No reasoning traces yet
            </Text>
            <Text fontSize="xs" color="gray.400" textAlign="center" mt={2} lineHeight="tall">
              Reasoning traces capture multi-step chains — the thoughts,
              actions, and observations an agent uses to reach a conclusion.
            </Text>
            <Box mt={3} textAlign="center">
              <Badge variant="outline" fontSize="xs" fontFamily="mono" px={2}>
                make seed
              </Badge>
            </Box>
          </Box>
        ) : (
          traces.map((trace) => (
            <Box
              key={trace.id}
              p={3}
              borderRadius="md"
              border="1px solid"
              borderColor={
                selectedTrace?.id === trace.id ? "blue.300" : "gray.200"
              }
              cursor="pointer"
              onClick={() => setSelectedTrace(trace)}
              _hover={{ borderColor: "blue.200" }}
            >
              <Text fontSize="sm" fontWeight="medium" lineClamp={2}>
                {trace.task}
              </Text>
              <HStack mt={1}>
                <Badge size="sm" variant="outline">
                  <Brain size={10} />
                  {trace.steps.length} steps
                </Badge>
                {trace.outcome && (
                  <Badge size="sm" colorPalette="green">
                    Resolved
                  </Badge>
                )}
                {hasFeedbackSignal(trace.feedback) && (
                  <Badge
                    size="sm"
                    colorPalette={
                      trace.feedback?.rating === "down"
                        ? "red"
                        : trace.feedback?.rating === "up"
                        ? "green"
                        : "purple"
                    }
                  >
                    {trace.feedback?.rating === "up" ? (
                      <ThumbsUp size={10} />
                    ) : trace.feedback?.rating === "down" ? (
                      <ThumbsDown size={10} />
                    ) : (
                      <MessageSquare size={10} />
                    )}
                    Reviewed
                  </Badge>
                )}
              </HStack>
            </Box>
          ))
        )}
      </VStack>

      {/* Selected trace detail — opens in a centered modal */}
      <Dialog.Root
        open={!!selectedTrace}
        onOpenChange={(e) => {
          if (!e.open) setSelectedTrace(null);
        }}
        size="lg"
        scrollBehavior="inside"
      >
        <Portal>
          <Dialog.Backdrop />
          <Dialog.Positioner>
            <Dialog.Content borderRadius="xl" overflow="hidden">
              <Dialog.CloseTrigger asChild>
                <CloseButton size="sm" />
              </Dialog.CloseTrigger>

              {/* Fixed header: task + at-a-glance metadata */}
              <Dialog.Header
                px={6}
                pt={5}
                pb={4}
                borderBottomWidth="1px"
                borderColor="gray.100"
              >
                <Box pr={6}>
                  <HStack gap={2} mb={2} align="flex-start">
                    <Box color="blue.500" mt="1px" flexShrink={0}>
                      <GitBranch size={16} />
                    </Box>
                    <Dialog.Title fontSize="sm" lineHeight="short">
                      {selectedTrace?.task}
                    </Dialog.Title>
                  </HStack>
                  <HStack gap={2}>
                    <Badge size="sm" variant="subtle" colorPalette="gray">
                      {selectedTrace?.steps.length} steps
                    </Badge>
                    {selectedTrace?.outcome && (
                      <Badge size="sm" variant="subtle" colorPalette="green">
                        Resolved
                      </Badge>
                    )}
                    {hasFeedbackSignal(selectedTrace?.feedback) && (
                      <Badge
                        size="sm"
                        variant="subtle"
                        colorPalette={
                          selectedTrace?.feedback?.rating === "down"
                            ? "red"
                            : selectedTrace?.feedback?.rating === "up"
                            ? "green"
                            : "purple"
                        }
                      >
                        Reviewed
                      </Badge>
                    )}
                  </HStack>
                </Box>
              </Dialog.Header>

              {/* Scrolling body: reasoning steps, outcome, feedback */}
              <Dialog.Body px={6} py={5}>
                {selectedTrace && (
                  <>
                    <VStack gap={3} align="stretch">
                      {selectedTrace.steps.map((step, i) => {
                        const stepNum = step.step_number ?? i + 1;
                        const noteShown =
                          openNotes.has(stepNum) || !!stepNoteValue(stepNum);
                        return (
                          <Box
                            key={`step-${i}-${(step.action || "").slice(0, 32)}`}
                            borderWidth="1px"
                            borderColor="gray.200"
                            borderRadius="lg"
                            p={3}
                          >
                            {/* Thought, prefixed with a step number chip */}
                            <HStack align="flex-start" gap={2.5}>
                              <Flex
                                flexShrink={0}
                                boxSize={5}
                                mt="1px"
                                borderRadius="full"
                                bg="blue.50"
                                color="blue.600"
                                align="center"
                                justify="center"
                                fontSize="2xs"
                                fontWeight="bold"
                              >
                                {stepNum}
                              </Flex>
                              <Text
                                fontSize="sm"
                                color="gray.700"
                                lineHeight="tall"
                                whiteSpace="pre-wrap"
                                wordBreak="break-word"
                              >
                                {step.thought}
                              </Text>
                            </HStack>

                            {/* Action (the Cypher that ran) */}
                            {step.action && (
                              <Box mt={2.5} pl={7}>
                                <HStack gap={1.5} mb={1} color="gray.400">
                                  <Wrench size={11} />
                                  <Text
                                    fontSize="2xs"
                                    fontWeight="semibold"
                                    letterSpacing="wide"
                                    textTransform="uppercase"
                                  >
                                    Action
                                  </Text>
                                </HStack>
                                <Box
                                  as="pre"
                                  fontSize="xs"
                                  fontFamily="mono"
                                  whiteSpace="pre-wrap"
                                  wordBreak="break-word"
                                  bg="gray.50"
                                  borderWidth="1px"
                                  borderColor="gray.100"
                                  color="gray.700"
                                  px={3}
                                  py={2}
                                  borderRadius="md"
                                >
                                  {step.action}
                                </Box>
                              </Box>
                            )}

                            {/* Result / observation */}
                            {step.observation && (
                              <Box mt={2.5} pl={7}>
                                <HStack gap={1.5} mb={1} color="gray.400">
                                  <Eye size={11} />
                                  <Text
                                    fontSize="2xs"
                                    fontWeight="semibold"
                                    letterSpacing="wide"
                                    textTransform="uppercase"
                                  >
                                    Result
                                  </Text>
                                </HStack>
                                <Text
                                  fontSize="xs"
                                  color="gray.600"
                                  whiteSpace="pre-wrap"
                                  wordBreak="break-word"
                                >
                                  {step.observation}
                                </Text>
                              </Box>
                            )}

                            {/* Per-step note — collapsed until requested */}
                            <Box mt={2} pl={7}>
                              {noteShown ? (
                                <Input
                                  size="xs"
                                  fontSize="xs"
                                  bg="white"
                                  placeholder="Note on this step…"
                                  value={stepNoteValue(stepNum)}
                                  onChange={(e) => setStepNote(stepNum, e.target.value)}
                                />
                              ) : (
                                <Button
                                  size="xs"
                                  variant="ghost"
                                  colorPalette="gray"
                                  color="gray.400"
                                  onClick={() => toggleStepNoteOpen(stepNum)}
                                >
                                  <MessageSquare size={11} /> Add note
                                </Button>
                              )}
                            </Box>
                          </Box>
                        );
                      })}
                    </VStack>

                    {selectedTrace.outcome && (
                      <Box
                        mt={4}
                        borderWidth="1px"
                        borderColor="green.200"
                        bg="green.50"
                        borderRadius="lg"
                        p={3}
                      >
                        <HStack gap={1.5} mb={1} color="green.700">
                          <Check size={12} />
                          <Text
                            fontSize="2xs"
                            fontWeight="bold"
                            letterSpacing="wide"
                            textTransform="uppercase"
                          >
                            Outcome
                          </Text>
                        </HStack>
                        <Text
                          fontSize="xs"
                          color="gray.700"
                          whiteSpace="pre-wrap"
                          wordBreak="break-word"
                        >
                          {selectedTrace.outcome}
                        </Text>
                      </Box>
                    )}

                    {/* Human-in-the-loop feedback — reviewers rate the reasoning
                        and leave guidance that is exported for guideline
                        curation. Grouped in one card; Save lives in the footer. */}
                    <Box
                      mt={4}
                      borderWidth="1px"
                      borderColor="gray.200"
                      bg="gray.50"
                      borderRadius="lg"
                      p={4}
                    >
                      <HStack gap={2} mb={1}>
                        <MessageSquare size={14} />
                        <Text fontSize="sm" fontWeight="bold">
                          Your feedback
                        </Text>
                      </HStack>
                      <Text fontSize="xs" color="gray.500" mb={4}>
                        Exported for curating agent guidelines & eval sets.
                      </Text>

                      <Text
                        fontSize="2xs"
                        fontWeight="semibold"
                        letterSpacing="wide"
                        textTransform="uppercase"
                        color="gray.400"
                        mb={1.5}
                      >
                        Verdict
                      </Text>
                      <HStack gap={2} mb={4}>
                        <Button
                          flex={1}
                          size="xs"
                          variant={draft.rating === "up" ? "solid" : "outline"}
                          colorPalette="green"
                          onClick={() => setRating("up")}
                          aria-label="Rate reasoning good"
                        >
                          <ThumbsUp size={13} /> Good
                        </Button>
                        <Button
                          flex={1}
                          size="xs"
                          variant={draft.rating === "down" ? "solid" : "outline"}
                          colorPalette="red"
                          onClick={() => setRating("down")}
                          aria-label="Rate reasoning bad"
                        >
                          <ThumbsDown size={13} /> Bad
                        </Button>
                      </HStack>

                      <Text
                        fontSize="2xs"
                        fontWeight="semibold"
                        letterSpacing="wide"
                        textTransform="uppercase"
                        color="gray.400"
                        mb={1.5}
                      >
                        Tags
                      </Text>
                      <Flex wrap="wrap" gap={1.5} mb={4}>
                        {FEEDBACK_TAGS.map((tag) => {
                          const active = (draft.tags || []).includes(tag);
                          return (
                            <Badge
                              key={tag}
                              cursor="pointer"
                              px={2}
                              py={1}
                              borderRadius="full"
                              variant={active ? "solid" : "outline"}
                              colorPalette={active ? "blue" : "gray"}
                              onClick={() => toggleTag(tag)}
                            >
                              {tag}
                            </Badge>
                          );
                        })}
                      </Flex>

                      <Text
                        fontSize="2xs"
                        fontWeight="semibold"
                        letterSpacing="wide"
                        textTransform="uppercase"
                        color="gray.400"
                        mb={1.5}
                      >
                        Guidance note
                      </Text>
                      <Textarea
                        value={draft.note || ""}
                        onChange={(e) => {
                          const value = e.target.value;
                          setDraft((d) => ({ ...d, note: value }));
                          setSaved(false);
                        }}
                        placeholder="What was right or wrong? What should the agent do next time?"
                        fontSize="xs"
                        bg="white"
                        rows={3}
                        mb={3}
                      />

                      <Input
                        value={draft.reviewer || ""}
                        onChange={(e) => {
                          const value = e.target.value;
                          setDraft((d) => ({ ...d, reviewer: value }));
                          setSaved(false);
                        }}
                        placeholder="Reviewer (optional)"
                        fontSize="xs"
                        bg="white"
                        size="sm"
                      />
                    </Box>
                  </>
                )}
              </Dialog.Body>

              {/* Pinned footer: the Save action is always reachable */}
              <Dialog.Footer
                px={6}
                py={4}
                borderTopWidth="1px"
                borderColor="gray.100"
              >
                <HStack justify="space-between" w="100%">
                  <Text fontSize="xs" color="gray.400">
                    {saved
                      ? draft.updated_at
                        ? `Saved ${new Date(draft.updated_at).toLocaleString()}`
                        : "Saved"
                      : hasFeedbackSignal(draft)
                      ? "Unsaved changes"
                      : "Not yet reviewed"}
                  </Text>
                  <HStack gap={3}>
                    {saved && (
                      <HStack gap={1} color="green.600">
                        <Check size={13} />
                        <Text fontSize="xs">Saved</Text>
                      </HStack>
                    )}
                    <Button
                      size="sm"
                      colorPalette="blue"
                      onClick={saveFeedback}
                      loading={saving}
                      loadingText="Saving"
                    >
                      Save feedback
                    </Button>
                  </HStack>
                </HStack>
              </Dialog.Footer>
            </Dialog.Content>
          </Dialog.Positioner>
        </Portal>
      </Dialog.Root>
    </Flex>
  );
}
{% endraw %}
